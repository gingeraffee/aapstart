# -- Google Sheets ------------------------------------------------
# Path to your Google service account credentials JSON file.
# See README.md for how to create this.
GOOGLE_CREDENTIALS_FILE=credentials.json

# Exact name of the Google Sheet (as it appears in Google Drive).
GOOGLE_SHEET_NAME=AAP New Hire Orientation Progress

# -- Authentication -----------------------------------------------
# The shared access code all employees use to log in.
ACCESS_CODE=AAP

# A long random string used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-this-with-a-long-random-string

JWT_ALGORITHM=HS256

# How long a login session lasts (in hours).
JWT_EXPIRATION_HOURS=8

# -- Development auth bypass --------------------------------------
# Set to true to skip Google Sheets login locally.
DEV_AUTH_BYPASS=false
DEV_AUTH_EMPLOYEE_ID=dev-001
DEV_AUTH_FULL_NAME=Dev User
DEV_AUTH_TRACK=hr

# -- Paths --------------------------------------------------------
# Path to the content directory, relative to the backend folder.
CONTENT_DIR=../content

# SQLite database file location.
DATABASE_URL=sqlite:///./data/progress.db

# -- CORS ---------------------------------------------------------
# URL of the Next.js frontend during local development.
FRONTEND_URL=http://localhost:3000
